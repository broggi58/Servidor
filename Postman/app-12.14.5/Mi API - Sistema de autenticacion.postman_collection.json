    {
      "name": "Registro",
      "item": [
        {
          "name": "Registrar Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Verificar que el status code sea 201 (Created)\r",
                  "pm.test(\"Status code es 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "// 2. Verificar que la respuesta tenga el mensaje de éxito\r",
                  "pm.test(\"Mensaje de éxito\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.message).to.eql(\"Usuario registrado exitosamente\");\r",
                  "});\r",
                  "\r",
                  "// 3. Verificar que el usuario tenga un ID (no nulo)\r",
                  "pm.test(\"Usuario tiene ID\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.user.id).to.be.a('number');\r",
                  "});\r",
                  "\r",
                  "// 4. Guardar el email registrado para usarlo en login (opcional)\r",
                  "pm.test(\"Guardar email para pruebas posteriores\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.environment.set(\"registeredEmail\", jsonData.user.email);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"test@postman.com\",\r\n  \"password\": \"Contraseña123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
